{
  "description": "Simple form normalizes to messages with ids system/user; hash is over the normalized document.",
  "document": {
    "name": "support-triage",
    "model": "anthropic/claude-haiku-4-5",
    "params": {
      "maxOutputTokens": 500
    },
    "output": {
      "urgency": [
        "low",
        "medium",
        "high"
      ],
      "summary": "string"
    },
    "system": "You triage support tickets for {{company}}. Be decisive.",
    "user": "Ticket: {{ticket}}"
  },
  "expect": {
    "variables": [
      "company",
      "ticket"
    ],
    "messageIds": [
      "system",
      "user"
    ],
    "contentHash": "aba20f590ab8e17c",
    "roundTrip": true
  },
  "cases": [
    {
      "variables": {
        "company": "Acme",
        "ticket": "Login is broken"
      },
      "messages": [
        {
          "role": "system",
          "id": "system",
          "content": "You triage support tickets for Acme. Be decisive."
        },
        {
          "role": "user",
          "id": "user",
          "content": "Ticket: Login is broken"
        }
      ]
    },
    {
      "variables": {
        "company": "Acme"
      },
      "error": true
    }
  ]
}
