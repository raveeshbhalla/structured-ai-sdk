{
  "name": "structured-ai-sdk",
  "version": "0.1.0",
  "description": "Structured prompt configs and typed templates for the Vercel AI SDK.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "docs",
    "dist",
    "prompt-config.schema.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./prompt-config.schema.json": "./prompt-config.schema.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "prepack": "npm run build",
    "sample:openai": "tsx samples/openai-triage.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "sample:template": "tsx samples/prompt-template.ts"
  },
  "peerDependencies": {
    "ai": "^7.0.0",
    "zod": "^3.25.76 || ^4.1.8"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "json-schema-to-ts": "^3.1.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^4.0.0",
    "@types/node": "^24.10.1",
    "ai": "^7.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13",
    "zod": "^4.1.13"
  }
}
